set(@INSTALL_CMAKE_NAMESPACE@_FOUND FALSE)

if(DEFINED BOBUI_REQUIRE_HOST_PATH_CHECK)
    set(__bobui_platform_requires_host_info_package "${BOBUI_REQUIRE_HOST_PATH_CHECK}")
elseif(DEFINED ENV{BOBUI_REQUIRE_HOST_PATH_CHECK})
    set(__bobui_platform_requires_host_info_package "$ENV{BOBUI_REQUIRE_HOST_PATH_CHECK}")
elseif(CMAKE_CROSSCOMPILING OR DEFINED BOBUI_HOST_PATH)
    set(__bobui_platform_requires_host_info_package "@platform_requires_host_info_package@")
else()
    set(__bobui_platform_requires_host_info_package FALSE)
endif()
set(__bobui_platform_initial_bobui_host_path "@bobui_host_path_absolute@")
set(__bobui_platform_initial_bobui_host_path_cmake_dir "@bobui_host_path_cmake_dir_absolute@")

_bobui_internal_setup_bobui_host_path(
    "${__bobui_platform_requires_host_info_package}"
    "${__bobui_platform_initial_bobui_host_path}"
    "${__bobui_platform_initial_bobui_host_path_cmake_dir}")
_bobui_internal_find_host_info_package(${__bobui_platform_requires_host_info_package}
    @INSTALL_CMAKE_NAMESPACE@)

# note: _third_party_deps example: "ICU\\;FALSE\\;1.0\\;i18n uc data;ZLIB\\;FALSE\\;\\;"
set(__bobui_third_party_deps "@third_party_deps@")
@third_party_deps_extra_info@
@third_party_extra@

# Don't propagate REQUIRED so we don't immediately FATAL_ERROR, rather let the find_dependency calls
# set _NOT_FOUND_MESSAGE which will be displayed by the includer of the Dependencies file.
set(${CMAKE_FIND_PACKAGE_NAME}_FIND_REQUIRED FALSE)

if(__bobui_third_party_deps)
    _bobui_internal_find_third_party_dependencies(@INSTALL_CMAKE_NAMESPACE@ __bobui_third_party_deps)
endif()

set(@INSTALL_CMAKE_NAMESPACE@_FOUND TRUE)
