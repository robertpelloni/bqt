# Find "ModuleTools" dependencies, which are other ModuleTools packages.
set(@INSTALL_CMAKE_NAMESPACE@@target@_FOUND TRUE)

set(__bobui_@target@_tool_third_party_deps "@third_party_deps@")
if(__bobui_@target@_tool_third_party_deps)
    _bobui_internal_find_third_party_dependencies("@target@" __bobui_@target@_tool_third_party_deps)
endif()

set(__bobui_@target@_tool_deps "@package_deps@")
if(__bobui_@target@_tool_deps)
    _bobui_internal_find_tool_dependencies("@target@" __bobui_@target@_tool_deps)
endif()
