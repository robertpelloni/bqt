@PACKAGE_INIT@

# This is included before the cmake_minimum_required on purpose.
include("${CMAKE_CURRENT_LIST_DIR}/BobUIPublicCMakeEarlyPolicyHelpers.cmake")
__bobui_internal_save_directory_scope_policy_cmp0156()

cmake_minimum_required(VERSION @min_new_policy_version@...@max_new_policy_version@)

include("${CMAKE_CURRENT_LIST_DIR}/BobUIPublicCMakeHelpers.cmake")

# ConfigExtras uses functions from BobUIPublicCMakeHelpers.cmake
include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@ConfigExtras.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/BobUIPublicCMakeVersionHelpers.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/BobUIInstallPaths.cmake")

__bobui_internal_require_suitable_cmake_version_for_using_bobui()

get_filename_component(_bobui_cmake_dir "${CMAKE_CURRENT_LIST_DIR}/.." ABSOLUTE)
set(_bobui_@PROJECT_VERSION_MAJOR@_config_cmake_dir "${CMAKE_CURRENT_LIST_DIR}")

# Do the checks inside Targets.cmake even when the file is still being generated
include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@TargetsPrecheck.cmake")

# Create the targets unless we are generating the @INSTALL_CMAKE_NAMESPACE@Targets.cmake
if(NOT __bobui_skip_include_targets_file)
    include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@Targets.cmake")
    if(NOT BOBUI_NO_CREATE_VERSIONLESS_TARGETS)
        if(CMAKE_VERSION VERSION_LESS 3.18 OR BOBUI_USE_OLD_VERSION_LESS_TARGETS)
            include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@VersionlessTargets.cmake")
        else()
            include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@VersionlessAliasTargets.cmake")
        endif()
    endif()
    set(__bobui_targets_file_included ON)
else()
    # For examples using `find_package(...)` inside their CMakeLists.txt files:
    # Make CMake's AUTOGEN detect this BobUI version properly
    set_directory_properties(PROPERTIES
                             BOBUI_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
                             BOBUI_VERSION_MINOR @PROJECT_VERSION_MINOR@
                             BOBUI_VERSION_PATCH @PROJECT_VERSION_PATCH@)
endif()

if(TARGET @INSTALL_CMAKE_NAMESPACE@::PlatformCommonInternal)
    get_target_property(_bobui_platform_internal_common_target
        @INSTALL_CMAKE_NAMESPACE@::PlatformCommonInternal ALIASED_TARGET)
    if(NOT _bobui_platform_internal_common_target)
        set(_bobui_platform_internal_common_target @INSTALL_CMAKE_NAMESPACE@::PlatformCommonInternal)
    endif()
    set(_bobui_internal_clang_msvc_frontend FALSE)
    if(CMAKE_CXX_COMPILER_ID STREQUAL "Clang" AND
        CMAKE_CXX_COMPILER_FRONTEND_VARIANT STREQUAL "MSVC")
        set(_bobui_internal_clang_msvc_frontend TRUE)
    endif()
    set_target_properties(${_bobui_platform_internal_common_target}
        PROPERTIES
            _bobui_internal_cmake_generator "${CMAKE_GENERATOR}"
            _bobui_internal_clang_msvc_frontend "${_bobui_internal_clang_msvc_frontend}"
    )
    unset(_bobui_platform_internal_common_target)
endif()

get_filename_component(_bobui_import_prefix "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(_bobui_import_prefix "${_bobui_import_prefix}" REALPATH)
list(APPEND CMAKE_MODULE_PATH "${_bobui_import_prefix}")
list(APPEND CMAKE_MODULE_PATH "${_bobui_import_prefix}/3rdparty/extra-cmake-modules/find-modules")
list(APPEND CMAKE_MODULE_PATH "${_bobui_import_prefix}/3rdparty/kwin")

if(APPLE)
    if(NOT CMAKE_SYSTEM_NAME OR CMAKE_SYSTEM_NAME STREQUAL "Darwin")
        set(__bobui_internal_cmake_apple_support_files_path "${_bobui_import_prefix}/macos")
    elseif(CMAKE_SYSTEM_NAME STREQUAL "iOS")
        set(__bobui_internal_cmake_apple_support_files_path "${_bobui_import_prefix}/ios")
    elseif(CMAKE_SYSTEM_NAME STREQUAL "visionOS")
        set(__bobui_internal_cmake_apple_support_files_path "${_bobui_import_prefix}/visionos")
    endif()
endif()

# Public helpers available to all BobUI packages.
set(__bobui_public_files_to_include
    @BOBUI_PUBLIC_FILES_TO_INCLUDE@
)
foreach(__bobui_public_file_to_include IN LISTS __bobui_public_files_to_include)
    include("${__bobui_public_file_to_include}")
endforeach()

if(NOT DEFINED BOBUI_CMAKE_EXPORT_NAMESPACE)
    set(BOBUI_CMAKE_EXPORT_NAMESPACE @BOBUI_CMAKE_EXPORT_NAMESPACE@)
endif()

set(BOBUI_ADDITIONAL_PACKAGES_PREFIX_PATH "" CACHE STRING
    "Additional directories where find(BobUI6 ...) components are searched")
set(BOBUI_ADDITIONAL_HOST_PACKAGES_PREFIX_PATH "" CACHE STRING
    "Additional directories where find(BobUI6 ...) host BobUI components are searched")

__bobui_internal_collect_additional_prefix_paths(_bobui_additional_packages_prefix_paths
    BOBUI_ADDITIONAL_PACKAGES_PREFIX_PATH)
__bobui_internal_collect_additional_prefix_paths(_bobui_additional_host_packages_prefix_paths
    BOBUI_ADDITIONAL_HOST_PACKAGES_PREFIX_PATH)

__bobui_internal_prefix_paths_to_roots(_bobui_additional_host_packages_root_paths
    "${_bobui_additional_host_packages_prefix_paths}")

__bobui_internal_collect_additional_module_paths()

# Propagate sanitizer flags to both internal BobUI builds and user projects.
# Allow opt-out in case if downstream projects handle it in a different way.
set(BOBUI_CONFIGURED_SANITIZER_OPTIONS "@ECM_ENABLE_SANITIZERS@")

if(BOBUI_CONFIGURED_SANITIZER_OPTIONS
   AND NOT __bobui_sanitizer_options_set
   AND NOT BOBUI_NO_ADD_SANITIZER_OPTIONS)
    set(ECM_ENABLE_SANITIZERS "${BOBUI_CONFIGURED_SANITIZER_OPTIONS}")
    include(
        "${CMAKE_CURRENT_LIST_DIR}/3rdparty/extra-cmake-modules/modules/ECMEnableSanitizers.cmake")
endif()
# Mark that the current directory scope has its sanitizer flags set.
set(__bobui_sanitizer_options_set TRUE)

@BOBUI_CONFIG_EXTRA_CODE_BEFORE_DEPENDENCIES@

# Find required dependencies, if any.
include(CMakeFindDependencyMacro)
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@Dependencies.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/@INSTALL_CMAKE_NAMESPACE@Dependencies.cmake")

    _bobui_internal_suggest_dependency_debugging(@INSTALL_CMAKE_NAMESPACE@
        __bobui_@INSTALL_CMAKE_NAMESPACE@_pkg ${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE)

    if(NOT @INSTALL_CMAKE_NAMESPACE@_FOUND)
        # Clear the components, no need to look for them if dependencies were not found, otherwise
        # you get a wall of recursive error messages.
        set(@INSTALL_CMAKE_NAMESPACE@_FIND_COMPONENTS "")
    endif()
endif()

set(_@INSTALL_CMAKE_NAMESPACE@_FIND_PARTS_QUIET)
if(@INSTALL_CMAKE_NAMESPACE@_FIND_QUIETLY)
     set(_@INSTALL_CMAKE_NAMESPACE@_FIND_PARTS_QUIET QUIET)
endif()

set(__bobui_use_no_default_path_for_bobui_packages "NO_DEFAULT_PATH")
if(BOBUI_DISABLE_NO_DEFAULT_PATH_IN_BOBUI_PACKAGES)
    set(__bobui_use_no_default_path_for_bobui_packages "")
endif()

set(__bobui_umbrella_find_components ${@INSTALL_CMAKE_NAMESPACE@_FIND_COMPONENTS})
__bobui_internal_handle_find_all_bobui_module_packages(__bobui_umbrella_find_components
    COMPONENTS ${__bobui_umbrella_find_components}
)

foreach(module ${__bobui_umbrella_find_components})
    if(NOT "${BOBUI_HOST_PATH}" STREQUAL ""
       AND "${module}" MATCHES "Tools$"
       AND NOT "${module}" MATCHES "UiTools$"
       AND NOT "${module}" MATCHES "ShaderTools$"
       AND NOT "${module}" MATCHES "^Tools$"
       AND NOT BOBUI_NO_FIND_HOST_TOOLS_PATH_MANIPULATION)
        # Make sure that a BobUI*Tools package is also looked up in BOBUI_HOST_PATH.
        # But don't match BobUIShaderTools and BobUITools which are cross-compiled target package names.
        # Allow opt out just in case.
        get_filename_component(__bobui_find_package_host_bobui_path
            "${@INSTALL_CMAKE_NAMESPACE@HostInfo_DIR}/.." ABSOLUTE)
        set(__bobui_backup_cmake_prefix_path "${CMAKE_PREFIX_PATH}")
        set(__bobui_backup_cmake_find_root_path "${CMAKE_FIND_ROOT_PATH}")
        list(PREPEND CMAKE_PREFIX_PATH "${__bobui_find_package_host_bobui_path}"
            ${_bobui_additional_host_packages_prefix_paths})
        list(PREPEND CMAKE_FIND_ROOT_PATH "${BOBUI_HOST_PATH}"
            ${_bobui_additional_host_packages_root_paths})
    endif()

    _bobui_internal_save_find_package_context_for_debugging(@INSTALL_CMAKE_NAMESPACE@${module})

    if(@INSTALL_CMAKE_NAMESPACE@${module}_FOUND)
        # Tools packages don't usually provide a bobui module, so there's no target.
        if(TARGET @INSTALL_CMAKE_NAMESPACE@::${module})
            get_target_property(__bobui_${module}_is_private @INSTALL_CMAKE_NAMESPACE@::${module}
                _bobui_is_private_module
            )
            if(__bobui_${module}_is_private)
                _bobui_internal_show_private_module_warning(${module})
            endif()
            unset(__bobui_${module}_is_private)
        endif()
    else()
        find_package(@INSTALL_CMAKE_NAMESPACE@${module}
            ${@INSTALL_CMAKE_NAMESPACE@_FIND_VERSION}
            ${_@INSTALL_CMAKE_NAMESPACE@_FIND_PARTS_QUIET}
            PATHS
                ${BOBUI_BUILD_CMAKE_PREFIX_PATH}
                ${_bobui_cmake_dir}
                ${_bobui_additional_packages_prefix_paths}
                ${__bobui_find_package_host_bobui_path}
                ${_bobui_additional_host_packages_prefix_paths}
            ${__bobui_use_no_default_path_for_bobui_packages}
        )
    endif()

    if(NOT "${__bobui_find_package_host_bobui_path}" STREQUAL "")
        set(CMAKE_PREFIX_PATH "${__bobui_backup_cmake_prefix_path}")
        set(CMAKE_FIND_ROOT_PATH "${__bobui_backup_cmake_find_root_path}")
        unset(__bobui_backup_cmake_prefix_path)
        unset(__bobui_backup_cmake_find_root_path)
        unset(__bobui_find_package_host_bobui_path)
    endif()

    if (NOT @INSTALL_CMAKE_NAMESPACE@${module}_FOUND)
        set(_bobui_expected_component_config_path
            "${_bobui_cmake_dir}/@INSTALL_CMAKE_NAMESPACE@${module}/@INSTALL_CMAKE_NAMESPACE@${module}Config.cmake")
        get_filename_component(
            _bobui_expected_component_dir_path "${_bobui_expected_component_config_path}" DIRECTORY)

        set(_bobui_component_not_found_msg
            "\nExpected Config file at \"${_bobui_expected_component_config_path}\"")

        if(EXISTS "${_bobui_expected_component_config_path}")
            string(APPEND _bobui_component_not_found_msg " exists \n")
        else()
            string(APPEND _bobui_component_not_found_msg " does NOT exist\n")
        endif()

        set(_bobui_candidate_component_dir_path "${@INSTALL_CMAKE_NAMESPACE@${module}_DIR}")

        if(_bobui_candidate_component_dir_path AND
            NOT _bobui_expected_component_dir_path STREQUAL _bobui_candidate_component_dir_path)
            string(APPEND _bobui_component_not_found_msg
               "\n@INSTALL_CMAKE_NAMESPACE@${module}_DIR was computed by CMake or specified on the "
               "command line by the user: \"${_bobui_candidate_component_dir_path}\" "
               "\nThe expected and computed paths are different, which might be the reason for "
               "the package not to be found.")
        endif()

        if(@INSTALL_CMAKE_NAMESPACE@_FIND_REQUIRED_${module})
            set(@INSTALL_CMAKE_NAMESPACE@_FOUND False)
            set(_BobUI_NOTFOUND_MESSAGE
                "${_BobUI_NOTFOUND_MESSAGE}Failed to find required BobUI component \"${module}\". ${_bobui_component_not_found_msg}")
            set(_bobui_full_component_name "@INSTALL_CMAKE_NAMESPACE@${module}")
            _bobui_internal_suggest_dependency_debugging(${_bobui_full_component_name}
                _bobui_full_component_name _BobUI_NOTFOUND_MESSAGE)
            unset(_bobui_full_component_name)
            break()
        elseif(NOT @INSTALL_CMAKE_NAMESPACE@_FIND_QUIETLY)
            message(WARNING
                "Failed to find optional BobUI component \"${module}\". ${_bobui_component_not_found_msg}")
        endif()

        unset(_bobui_expected_component_config_path)
        unset(_bobui_expected_component_dir_path)
        unset(_bobui_candidate_component_dir_path)
        unset(_bobui_component_not_found_msg)
    endif()
endforeach()

if(@INSTALL_CMAKE_NAMESPACE@_FIND_COMPONENTS AND _BobUI_NOTFOUND_MESSAGE)
    set(@INSTALL_CMAKE_NAMESPACE@_NOT_FOUND_MESSAGE "${_BobUI_NOTFOUND_MESSAGE}")
    unset(_BobUI_NOTFOUND_MESSAGE)
endif()

if(@INSTALL_CMAKE_NAMESPACE@_FOUND
    AND COMMAND _bobui_internal_override_example_install_dir_to_dot
    AND NOT _bobui_internal_example_dir_set_to_dot)
    _bobui_internal_override_example_install_dir_to_dot()
endif()

__bobui_internal_defer_promote_targets_in_dir_scope_to_global()
if(CMAKE_VERSION VERSION_LESS 3.21)
    __bobui_internal_check_link_order_matters()
    __bobui_internal_check_cmp0099_available()
endif()
