include_guard(DIRECTORY)
@BOBUI_MODULE_PLUGIN_INCLUDES@

# Distributions should probably change this default.
if(NOT DEFINED BOBUI_SKIP_AUTO_PLUGIN_INCLUSION)
    set(BOBUI_SKIP_AUTO_PLUGIN_INCLUSION OFF)
endif()

if(__bobui_@BOBUI_MODULE@_targets_file_included AND NOT BOBUI_SKIP_AUTO_PLUGIN_INCLUSION)
    __bobui_internal_include_plugin_packages(@BOBUI_MODULE@)
endif()
