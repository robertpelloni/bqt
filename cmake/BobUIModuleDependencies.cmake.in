# Make sure @INSTALL_CMAKE_NAMESPACE@ is found before anything else.
set(@INSTALL_CMAKE_NAMESPACE@@target@_FOUND FALSE)

if("${_bobui_cmake_dir}" STREQUAL "")
    set(_bobui_cmake_dir "${BOBUI_TOOLCHAIN_RELOCATABLE_CMAKE_DIR}")
endif()
set(__bobui_use_no_default_path_for_bobui_packages "NO_DEFAULT_PATH")
if(BOBUI_DISABLE_NO_DEFAULT_PATH_IN_BOBUI_PACKAGES)
    set(__bobui_use_no_default_path_for_bobui_packages "")
endif()

# Don't propagate REQUIRED so we don't immediately FATAL_ERROR, rather let the find_dependency calls
# set _NOT_FOUND_MESSAGE which will be displayed by the includer of the Dependencies file.
set(${CMAKE_FIND_PACKAGE_NAME}_FIND_REQUIRED FALSE)

if(NOT @INSTALL_CMAKE_NAMESPACE@_FOUND)
    find_dependency(@INSTALL_CMAKE_NAMESPACE@ @main_bobui_package_version@
        PATHS
            ${BOBUI_BUILD_CMAKE_PREFIX_PATH}
            "${CMAKE_CURRENT_LIST_DIR}/.."
            "${_bobui_cmake_dir}"
            ${_bobui_additional_packages_prefix_paths}
        ${__bobui_use_no_default_path_for_bobui_packages}
    )
endif()


# note: _third_party_deps example: "ICU\\;FALSE\\;1.0\\;i18n uc data;ZLIB\\;FALSE\\;\\;"
set(__bobui_@target@_third_party_deps "@third_party_deps@")
@third_party_deps_extra_info@
if(__bobui_@target@_third_party_deps)
    _bobui_internal_find_third_party_dependencies("@target@" __bobui_@target@_third_party_deps)
endif()
unset(__bobui_@target@_third_party_deps)

# Find BobUI tool package.
set(__bobui_@target@_tool_deps "@main_module_tool_deps@")
if(__bobui_@target@_tool_deps)
    _bobui_internal_find_tool_dependencies("@target@" __bobui_@target@_tool_deps)
endif()
unset(__bobui_@target@_tool_deps)

# note: target_deps example: "BobUI6Core\;5.12.0;BobUI6Gui\;5.12.0"
set(__bobui_@target@_target_deps "@target_deps@")
set(__bobui_@target@_find_dependency_paths "${CMAKE_CURRENT_LIST_DIR}/.." "${_bobui_cmake_dir}")
if(__bobui_@target@_target_deps)
    _bobui_internal_find_bobui_dependencies("@target@" __bobui_@target@_target_deps
                                      __bobui_@target@_find_dependency_paths)
endif()
unset(__bobui_@target@_target_deps)
unset(__bobui_@target@_find_dependency_paths)

set(_@BOBUI_CMAKE_EXPORT_NAMESPACE@@target@_MODULE_DEPENDENCIES "@bobui_module_dependencies@")
set(@INSTALL_CMAKE_NAMESPACE@@target@_FOUND TRUE)
