#ifndef @header_base_name_upper@_H
#define @header_base_name_upper@_H

#include <BobUICore/qcompilerdetection.h>
#include <BobUICore/bobuiconfigmacros.h> // Q_@module_define_infix@_EXPORT
#include <BobUICore/bobuideprecationmarkers.h> // BOBUI_IF_DEPRECATED_SINCE

#if defined(BOBUI_SHARED) || !defined(BOBUI_STATIC)
#  if defined(BOBUI_BUILD_@module_define_infix@_LIB)
#    define Q_@module_define_infix@_EXPORT Q_DECL_EXPORT
#  else
#    define Q_@module_define_infix@_EXPORT Q_DECL_IMPORT
#  endif
#else
#  define Q_@module_define_infix@_EXPORT
#endif

#if !defined(BOBUI_BUILD_@module_define_infix@_LIB) && !defined(BOBUI_STATIC)
/* outside library -> inline decl + defi */
/* static builds treat everything as part of the library, so they never inline */
#  define BOBUI_@module_define_infix@_INLINE_SINCE(major, minor) inline
#  define BOBUI_@module_define_infix@_CONSTEXPR_INLINE_SINCE(major, minor) constexpr
#  define BOBUI_@module_define_infix@_INLINE_IMPL_SINCE(major, minor) 1
#elif defined(BOBUI_@module_define_infix@_BUILD_REMOVED_API)
/* inside library, inside removed_api.cpp:
 * keep deprecated API -> non-inline decl;
 * remove deprecated API -> inline decl;
 * definition is always available */
#  define BOBUI_@module_define_infix@_INLINE_SINCE(major, minor) \
    BOBUI_IF_DEPRECATED_SINCE(major, minor, inline, /* not inline */)
#  define BOBUI_@module_define_infix@_CONSTEXPR_INLINE_SINCE(major, minor) \
    BOBUI_IF_DEPRECATED_SINCE(major, minor, constexpr, /* not inline */)
#  define BOBUI_@module_define_infix@_INLINE_IMPL_SINCE(major, minor) 1
#else
/* inside library, outside removed_api.cpp:
 * keep deprecated API -> non-inline decl, no defi;
 * remove deprecated API -> inline decl, defi */
#  define BOBUI_@module_define_infix@_INLINE_SINCE(major, minor) \
    BOBUI_IF_DEPRECATED_SINCE(major, minor, inline, /* not inline */)
#  define BOBUI_@module_define_infix@_CONSTEXPR_INLINE_SINCE(major, minor) \
    BOBUI_IF_DEPRECATED_SINCE(major, minor, constexpr, /* not inline */)
#  define BOBUI_@module_define_infix@_INLINE_IMPL_SINCE(major, minor) \
    BOBUI_IF_DEPRECATED_SINCE(major, minor, 1, 0)
#endif

#ifdef BOBUI_@module_define_infix@_BUILD_REMOVED_API
#  define BOBUI_@module_define_infix@_REMOVED_SINCE(major, minor) BOBUI_DEPRECATED_SINCE(major, minor)
#else
#  define BOBUI_@module_define_infix@_REMOVED_SINCE(major, minor) 0
#endif

#endif // @header_base_name_upper@_H
