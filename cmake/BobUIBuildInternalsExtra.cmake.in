# Propagate usage of ccache.
set(BOBUI_USE_CCACHE @BOBUI_USE_CCACHE@ CACHE BOOL "Enable the use of ccache")

# Propagate usage of vcpkg, ON by default.
set(BOBUI_USE_VCPKG @BOBUI_USE_VCPKG@ CACHE BOOL "Enable the use of vcpkg")

# Propagate usage of unity build.
set(BOBUI_UNITY_BUILD @BOBUI_UNITY_BUILD@ CACHE BOOL "Enable unity (jumbo) build")
