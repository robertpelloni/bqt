    "Enable the use of versioned hard link")

# The minimum version required to build BobUI.
set(BOBUI_SUPPORTED_MIN_CMAKE_VERSION_FOR_BUILDING_BOBUI "@supported_min_version_for_building_bobui@")
set(BOBUI_COMPUTED_MIN_CMAKE_VERSION_FOR_BUILDING_BOBUI "@computed_min_version_for_building_bobui@")

# The lower and upper CMake version policy range as computed by bobuibase.
# These values are inherited when building other BobUI repositories, unless overridden
# in the respective repository .cmake.conf file.
# These are not cache variables, so that they can be overridden in each repo directory scope.
if(NOT DEFINED BOBUI_MIN_NEW_POLICY_CMAKE_VERSION)
    set(BOBUI_MIN_NEW_POLICY_CMAKE_VERSION "@min_new_policy_version@")
endif()
if(NOT DEFINED BOBUI_MAX_NEW_POLICY_CMAKE_VERSION)
    set(BOBUI_MAX_NEW_POLICY_CMAKE_VERSION "@max_new_policy_version@")
endif()

# Extra set of exported variables
@BOBUI_EXTRA_BUILD_INTERNALS_VARS@
