    "Boolean indicating if doing a BobUI prefix build (vs non-prefix build)." FORCE)

set(BOBUI_SOURCE_TREE "@BOBUI_SOURCE_TREE@" CACHE PATH
"A path to the source tree of the previously configured BobUIBase project." FORCE)

