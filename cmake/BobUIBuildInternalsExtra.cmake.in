# Propagate common variables via BuildInternals package.
set(BOBUI_BUILD_SHARED_LIBS @BUILD_SHARED_LIBS@)
option(BUILD_SHARED_LIBS "Build BobUI statically or dynamically" @BUILD_SHARED_LIBS@)
set(BOBUI_CMAKE_EXPORT_NAMESPACE @BOBUI_CMAKE_EXPORT_NAMESPACE@)
set(INSTALL_CMAKE_NAMESPACE @INSTALL_CMAKE_NAMESPACE@)
set(BOBUI_BUILD_INTERNALS_PATH "${CMAKE_CURRENT_LIST_DIR}")

# The relocatable install prefix is meant to be used to find things like host binaries (syncbobui),
# when the CMAKE_INSTALL_PREFIX is overridden to point to a different path (like when building a
# a BobUI repo using Conan, which will set a random install prefix instead of installing into the
# original BobUI install prefix).
get_filename_component(BOBUI_BUILD_INTERNALS_RELOCATABLE_INSTALL_PREFIX
                       ${CMAKE_CURRENT_LIST_DIR}/../@bobui_path_from_cmake_config_dir_to_prefix@
                       ABSOLUTE)

# Stores in out_var the new install/staging prefix for this build.
#
# new_prefix: the new prefix for this repository
# orig_prefix: the prefix that was used when bobuibase was configured
#
# On Windows hosts: if the original prefix does not start with a drive letter, this function removes
# the drive letter from the new prefix. This is needed for installation with DESTDIR set.
function(bobui_internal_new_prefix out_var new_prefix orig_prefix)
    if(CMAKE_HOST_WIN32)
        set(drive_letter_regexp "^[a-zA-Z]:")
        if(new_prefix MATCHES "${drive_letter_regexp}"
            AND NOT orig_prefix MATCHES "${drive_letter_regexp}")
            string(SUBSTRING "${new_prefix}" 2 -1 new_prefix)
        endif()
    endif()
    set(${out_var} "${new_prefix}" PARENT_SCOPE)
endfunction()

# If no explicit CMAKE_INSTALL_PREFIX is provided, force set the original BobUI installation prefix,
# so that further modules / repositories are  installed into same original location.
# This means by default when configuring bobuisvg / bobuideclarative, they will be installed the regular
# BobUI installation prefix.
# If an explicit installation prefix is specified,  honor it.
# This is an attempt to support Conan, aka handle installation of modules into a
# different installation prefix than the original one. Also allow to opt out via a special variable.
# In a top-level build, BobUISetup.cmake takes care of setting CMAKE_INSTALL_PREFIX.
if(CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT AND
        NOT BOBUI_BUILD_INTERNALS_NO_FORCE_SET_INSTALL_PREFIX
        AND NOT BOBUI_SUPERBUILD)
    set(bobuibi_orig_prefix "@CMAKE_INSTALL_PREFIX@")
    set(bobuibi_orig_staging_prefix "@CMAKE_STAGING_PREFIX@")
    bobui_internal_new_prefix(bobuibi_new_prefix
        "${BOBUI_BUILD_INTERNALS_RELOCATABLE_INSTALL_PREFIX}"
        "${bobuibi_orig_prefix}")
    if(NOT bobuibi_orig_staging_prefix STREQUAL ""
            AND "${CMAKE_STAGING_PREFIX}" STREQUAL ""
            AND NOT BOBUI_BUILD_INTERNALS_NO_FORCE_SET_STAGING_PREFIX)
        bobui_internal_new_prefix(bobuibi_new_staging_prefix
            "${bobuibi_new_prefix}"
            "${bobuibi_orig_staging_prefix}")
        set(CMAKE_STAGING_PREFIX "${bobuibi_new_staging_prefix}" CACHE PATH
            "Staging path prefix, prepended onto install directories on the host machine." FORCE)
        set(bobuibi_new_prefix "${bobuibi_orig_prefix}")
    endif()
    set(CMAKE_INSTALL_PREFIX "${bobuibi_new_prefix}" CACHE PATH
        "Install path prefix, prepended onto install directories." FORCE)
    unset(bobuibi_orig_prefix)
    unset(bobuibi_new_prefix)
    unset(bobuibi_orig_staging_prefix)
    unset(bobuibi_new_staging_prefix)
endif()

# Propagate developer builds to other modules via BuildInternals package.
if(@FEATURE_developer_build@)
    set(FEATURE_developer_build ON CACHE BOOL "Developer build." FORCE)
endif()

