cmake_minimum_required(VERSION 3.16)
project(proto_project LANGUAGES CXX)

find_package(BobUI6 REQUIRED COMPONENTS Protobuf Grpc)
bobui_standard_project_setup(REQUIRES 6.8)

bobui_add_protobuf(proto_project
    GENERATE_PACKAGE_SUBFOLDERS
    PROTO_FILES
        test.proto
)

target_link_libraries(proto_project
    PRIVATE
        BobUI::Protobuf
        BobUI::Grpc
)
