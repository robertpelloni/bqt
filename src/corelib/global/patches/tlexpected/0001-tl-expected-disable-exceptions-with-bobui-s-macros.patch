 src/corelib/global/qexpected_p.h | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/corelib/global/qexpected_p.h b/src/corelib/global/qexpected_p.h
index a54aea1f7d7..45c6196c947 100644
