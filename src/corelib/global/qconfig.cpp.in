/* This file is used to generate the BobUI configuration info for the Core library.
 * The 'bobui_generate_qconfig_cpp' cmake routine
 * contains variables that replace '@' entries in this file. It's important to
 * align these values with the following:
 *
 * - QLibraryInfo::LibraryPath enum in bobuibase/src/corelib/global/qlibraryinfo.h
 * - bobuiConfEntries in bobuibase/src/corelib/global/qlibraryinfo.cpp
 */
#include "private/qoffsetstringarray_p.h"

/* Installation Info */
static const char bobui_configure_prefix_path_str  [12+256] = "bobui_prfxpath=@BOBUI_CONFIGURE_PREFIX_PATH_STR@";

static constexpr auto bobui_configure_strs = BOBUI_PREPEND_NAMESPACE(qOffsetStringArray)(
@BOBUI_CONFIG_STRS@
);

#define BOBUI_CONFIGURE_SETTINGS_PATH "@BOBUI_SYS_CONF_DIR@"
#define BOBUI_CONFIGURE_LIBLOCATION_TO_PREFIX_PATH "@BOBUI_CONFIGURE_LIBLOCATION_TO_PREFIX_PATH@"_L1
#define BOBUI_CONFIGURE_PREFIX_PATH bobui_configure_prefix_path_str + 12
