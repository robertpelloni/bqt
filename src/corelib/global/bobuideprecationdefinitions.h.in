#ifndef BOBUIDEPRECATIONDEFINITIONS_H
#define BOBUIDEPRECATIONDEFINITIONS_H

#include <BobUICore/qcompilerdetection.h>

#ifndef BOBUI_DISABLE_DEPRECATED_UP_TO
#  ifdef BOBUI_DISABLE_DEPRECATED_BEFORE // If the deprecated macro is defined, use its value
#    define BOBUI_DISABLE_DEPRECATED_UP_TO BOBUI_DISABLE_DEPRECATED_BEFORE
#  else
#    define BOBUI_DISABLE_DEPRECATED_UP_TO @BOBUI_DISABLE_DEPRECATED_UP_TO@
#  endif
#endif

#if BOBUI_DISABLE_DEPRECATED_UP_TO < @BOBUI_DISABLE_DEPRECATED_UP_TO@ && defined(Q_CC_GNU)
#  warning BOBUI_DISABLE_DEPRECATED_UP_TO is set to the version that is lower than the version that \
           BobUI was built with. This may lead to linking issues.
#endif

#ifndef BOBUI_WARN_DEPRECATED_UP_TO
#  ifdef BOBUI_DEPRECATED_WARNINGS_SINCE // If the deprecated macro is defined, use its value
#    define BOBUI_WARN_DEPRECATED_UP_TO BOBUI_DEPRECATED_WARNINGS_SINCE
#  else
#    define BOBUI_WARN_DEPRECATED_UP_TO @BOBUI_WARN_DEPRECATED_UP_TO@
#  endif
#endif

#endif // BOBUIDEPRECATIONDEFINITIONS_H
